# ═══════════════════════════════════════════
# SHIELD Backend — Environment Configuration
# ═══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=shield-safety-secret-key-2026-change-in-production

# SMS Provider (demo mode for testing)
SMS_PROVIDER=demo

# Database (JSON file-based for now)
DB_TYPE=json_file

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
